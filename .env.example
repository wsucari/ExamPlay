# Copia este archivo como .env y carga las variables en tu entorno.
SECRET_KEY=cambia-esto-por-una-clave-larga-y-aleatoria
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
CSRF_TRUSTED_ORIGINS=
SECURE_SSL_REDIRECT=True
SECURE_HSTS_SECONDS=31536000
SECURE_HSTS_INCLUDE_SUBDOMAINS=True
SECURE_HSTS_PRELOAD=True

# Vacío usa SQLite. Render proporciona una URL postgres://...
DATABASE_URL=

# Vacío usa InMemoryChannelLayer (solo desarrollo de un proceso).
REDIS_URL=
